@model List<TiendaVentas.Web.Models.Banner>

@{
    ViewData["Title"] = "Administrar Banners";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-bold mb-1">Panel de Banners</h1>
            <p class="text-muted mb-0">Administra el slider principal de la tienda.</p>
        </div>

        <a asp-action="Create" class="btn btn-dark rounded-pill">
            Nuevo banner
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow rounded-4">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Preview</th>
                            <th>Título</th>
                            <th>Orden</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@item.Imagen_Url"
                                         style="width:120px; height:60px; object-fit:cover; border-radius:10px;" />
                                </td>

                                <td>
                                    <strong>@item.Titulo</strong><br />
                                    <small class="text-muted">@item.Subtitulo</small>
                                </td>

                                <td>@item.Orden</td>

                                <td>
                                    @if (item.Estado == "A")
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end flex-wrap">
                                        <a asp-action="Edit"
                                               asp-route-id="@item.Id_Banner"
                                               class="btn btn-sm btn-outline-primary rounded-pill">
                                            Editar
                                        </a>

                                        @if (item.Estado == "A")
                                        {
                                            <form asp-action="Desactivar" method="post">
                                                <input type="hidden" name="id" value="@item.Id_Banner" />
                                                <button class="btn btn-sm btn-outline-danger rounded-pill">
                                                    Desactivar
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Activar" method="post">
                                                <input type="hidden" name="id" value="@item.Id_Banner" />
                                                <button class="btn btn-sm btn-outline-success rounded-pill">
                                                    Activar
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center rounded-4">
            No hay banners registrados.
        </div>
    }
</div>