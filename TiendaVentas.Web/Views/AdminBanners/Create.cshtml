@model TiendaVentas.Web.Models.Banner

@{
    ViewData["Title"] = "Nuevo Banner";
}

<div class="container py-4">
    <h1 class="fw-bold mb-3">Nuevo Banner</h1>

    <div class="card shadow rounded-4 border-0">
        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input asp-for="Titulo" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Subtítulo</label>
                    <input asp-for="Subtitulo" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagen</label>
                    <input type="file" name="imagen" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Texto botón</label>
                    <input asp-for="Boton_Texto" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">URL botón</label>
                    <input asp-for="Boton_Url" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Orden</label>
                    <input asp-for="Orden" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Estado</label>
                    <select asp-for="Estado" class="form-select rounded-3">
                        <option value="A">Activo</option>
                        <option value="I">Inactivo</option>
                    </select>
                </div>

                <button class="btn btn-dark rounded-pill px-4">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancelar</a>

            </form>

        </div>
    </div>
</div>