@model TiendaVentas.Web.Models.HomeViewModel

@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-4 mb-5 pb-5">

    <!-- SLIDER DINÁMICO -->
    <section class="home-slider-section mb-5">
        @if (Model.Banners != null && Model.Banners.Any())
        {
            <div id="mcNailsSlider"
                 class="carousel slide carousel-fade"
                 data-bs-ride="carousel"
                 data-bs-interval="4500">

                <!-- INDICADORES -->
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Banners.Count; i++)
                    {
                        <button type="button"
                                data-bs-target="#mcNailsSlider"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")">
                        </button>
                    }
                </div>

                <!-- SLIDES -->
                <div class="carousel-inner mc-slider-wrapper rounded-5 shadow-sm">

                    @for (int i = 0; i < Model.Banners.Count; i++)
                    {
                        var banner = Model.Banners[i];

                        <div class="carousel-item @(i == 0 ? "active" : "")">

                            <img src="@banner.Imagen_Url"
                                 class="d-block w-100 slider-img"
                                 alt="@banner.Titulo" />

                            @if (!string.IsNullOrWhiteSpace(banner.Titulo) ||
                                 !string.IsNullOrWhiteSpace(banner.Subtitulo) ||
                                 !string.IsNullOrWhiteSpace(banner.Boton_Texto))
                            {
                                <div class="carousel-caption slider-caption">

                                    @if (!string.IsNullOrWhiteSpace(banner.Titulo))
                                    {
                                        <h1>@banner.Titulo</h1>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(banner.Subtitulo))
                                    {
                                        <p>@banner.Subtitulo</p>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(banner.Boton_Texto) &&
                                         !string.IsNullOrWhiteSpace(banner.Boton_Url))
                                    {
                                        <div class="d-flex gap-3 flex-wrap">
                                            <a href="@banner.Boton_Url"
                                                   class="btn btn-slider-primary">
                                                @banner.Boton_Texto
                                            </a>
                                        </div>
                                    }

                                </div>
                            }

                        </div>
                    }

                </div>

                <!-- CONTROLES -->
                <button class="carousel-control-prev custom-arrow"
                        type="button"
                        data-bs-target="#mcNailsSlider"
                        data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next custom-arrow"
                        type="button"
                        data-bs-target="#mcNailsSlider"
                        data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

            </div>
        }
        else
        {
            <div class="alert alert-warning text-center rounded-4">
                No hay banners activos registrados.
            </div>
        }
    </section>

    <!-- MINI INFO -->
    <section class="mb-5">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="mini-banner text-center">
                    <div class="mini-banner-title">Productos seleccionados</div>
                    <p class="text-muted">Encuentra todo más rápido.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="mini-banner text-center">
                    <div class="mini-banner-title">Pedidos fáciles</div>
                    <p class="text-muted">Compra rápido por WhatsApp.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="mini-banner text-center">
                    <div class="mini-banner-title">Estilo MC Nails</div>
                    <p class="text-muted">Diseño moderno y limpio.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CATEGORÍAS -->
    <section class="categories-showcase mb-5">
        <div class="text-center mb-5">
            <h2 class="categories-title">CATEGORÍAS</h2>
            <div class="categories-line"></div>
            <p class="categories-subtitle">
                Descubre nuestras líneas de productos y encuentra fácilmente lo que necesitas.
            </p>
        </div>

        <div class="row g-4 justify-content-center">
            @if (Model.Categorias != null && Model.Categorias.Any())
            {
                @foreach (var categoria in Model.Categorias)
                {
                    var imagen = string.IsNullOrWhiteSpace(categoria.Imagen_Url)
                        ? "/images/no-image.png"
                        : categoria.Imagen_Url;

                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <a asp-controller="Productos"
                               asp-action="Index"
                               asp-route-idCategoria="@categoria.Id_Categoria"
                               class="category-image-link">

                            <div class="category-image-card">

                                <div class="category-image-box">
                                    <img src="@imagen"
                                         alt="@categoria.Nombre"
                                         class="category-photo" />
                                </div>

                                <div class="category-button-name">
                                    @categoria.Nombre
                                </div>

                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </section>

</div>