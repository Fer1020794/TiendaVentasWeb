@model TiendaVentas.Web.Models.Pedido

@{
    ViewData["Title"] = "Pedido Confirmado";

    var telefonoWhatsApp = ViewBag.TelefonoWhatsApp?.ToString() ?? "50254001440";
    var mensaje = $"Hola, he realizado el pedido No. {Model.Id_Pedido:D6} en MC Nails. Quedo atento(a) a la confirmación.";
    var whatsappUrl = $"https://wa.me/{telefonoWhatsApp}?text={Uri.EscapeDataString(mensaje)}";
}

<div class="container py-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow rounded-4">
                <div class="card-body p-5 text-center">

                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    </div>

                    <h1 class="fw-bold mb-3">Pedido generado correctamente</h1>

                    <p class="text-muted mb-4">
                        Tu pedido fue registrado exitosamente en el sistema.
                    </p>

                    <div class="bg-light rounded-4 p-4 mb-4">
                        <h5 class="fw-bold mb-3">Resumen del pedido</h5>
                        <p class="mb-2"><strong>No. de pedido:</strong> @Model.Id_Pedido.ToString("D6")</p>
                        <p class="mb-2"><strong>Cliente:</strong> @Model.Nombre_Cliente</p>
                        <p class="mb-2"><strong>Total:</strong> Q @Model.Total.ToString("N2")</p>
                        <p class="mb-0"><strong>Estado:</strong> @Model.Estado</p>
                    </div>

                    <div class="d-flex justify-content-center flex-wrap gap-3">
                        <a href="@whatsappUrl" target="_blank" class="btn btn-success rounded-pill px-4">
                            Abrir WhatsApp
                        </a>

                        @if (!string.IsNullOrWhiteSpace(Model.Pdf_Url))
                        {
                            <a href="@Model.Pdf_Url" target="_blank" class="btn btn-outline-dark rounded-pill px-4">
                                Ver PDF
                            </a>
                        }

                        <a asp-controller="Productos" asp-action="Index" class="btn btn-dark rounded-pill px-4">
                            Seguir comprando
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>