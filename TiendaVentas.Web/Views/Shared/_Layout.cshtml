<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MC Nails</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TiendaVentas.Web.styles.css" asp-append-version="true" />
</head>

<body>

    <header class="top-store-header">
        <div class="container py-3">

            <div class="row align-items-center g-3">
                <div class="col-lg-3">
                    <a class="d-flex align-items-center gap-3 text-decoration-none" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo-mc-nails.jpg" alt="MC Nails" class="logo-mc" />
                        <div>
                            <div class="brand-title">MC Nails</div>
                            <div class="brand-subtitle">Maria Cibeles</div>
                        </div>
                    </a>
                </div>

                <div class="col-lg-6">
                    <form asp-controller="Productos" asp-action="Index" method="get" class="mc-search-box d-flex mx-auto" autocomplete="off">
                        <input type="text"
                               name="texto"
                               class="form-control"
                               placeholder="Buscar productos..."
                               autocomplete="off" />

                        <button type="submit" aria-label="Buscar">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                </div>

                <div class="col-lg-3 d-flex justify-content-lg-end">
                    @await Component.InvokeAsync("CarritoResumen")
                </div>
            </div>

            <nav class="navbar navbar-expand-lg navbar-light mt-3">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Productos" asp-action="Index">Productos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#">Nosotros</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#">Contacto</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center flex-wrap gap-2">
                        @if (Context.Session.GetString("ADMIN_LOGUEADO") == "SI")
                        {
                            <span class="fw-semibold text-muted">
                                <i class="bi bi-person-circle"></i>
                                @Context.Session.GetString("ADMIN_NOMBRE")
                            </span>

                            <a asp-controller="AdminProductos" asp-action="Index"
                                   class="btn btn-sm btn-dark rounded-pill">
                                Panel
                            </a>

                            <a asp-controller="AdminAuth" asp-action="Logout"
                                   class="btn btn-sm btn-outline-danger rounded-pill">
                                Salir
                            </a>
                        }
                        else
                        {
                            <a asp-controller="AdminAuth" asp-action="Login"
                                   class="btn btn-outline-secondary rounded-pill d-flex align-items-center gap-2">
                                <i class="bi bi-shield-lock"></i>
                                Admin
                            </a>
                        }

                        <a href="https://wa.me/50254001440" target="_blank" class="btn btn-whatsapp">
                            Pedidos por WhatsApp
                        </a>
                    </div>
                </div>
            </nav>

        </div>
    </header>

    <div class="container py-4 main-container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container text-center py-4">
            <p class="mb-2 fw-semibold">&copy; 2026 - MC Nails</p>

            <small class="d-block mb-3">
                Tienda en línea de productos para uñas y belleza
            </small>

            <div class="d-flex justify-content-center gap-3">
                <a href="https://www.facebook.com/share/1CkLbgcech/"
                       target="_blank"
                       class="social-icon fb">
                    <i class="bi bi-facebook"></i>
                </a>

                <a href="https://www.instagram.com/mcnailsguatemala?igsh=MXdsYXE3dW9pMzFkaw=="
                       target="_blank"
                       class="social-icon ig">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="https://www.tiktok.com/@@mcnails.guatemala?_r=1&_t=ZS-95WEelkuU5a"
                       target="_blank"
                       class="social-icon tk">
                    <i class="bi bi-tiktok"></i>
                </a>
            </div>
        </div>
    </footer>

    <div class="mc-whatsapp-widget" id="whatsappWidget">
        <div class="mc-whatsapp-box">
            <div class="mc-whatsapp-header">
                ¡Contáctanos por WhatsApp y te atenderemos lo más pronto posible!
                <button type="button" class="mc-whatsapp-close" onclick="document.getElementById('whatsappWidget').style.display='none'">
                    ×
                </button>
            </div>

            <div class="mc-whatsapp-body">
                <div class="mc-whatsapp-message">
                    <div class="mc-whatsapp-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        <div class="mc-whatsapp-small">Atención al cliente</div>
                        <div class="fw-bold">Pulsa para enviar un WhatsApp</div>
                    </div>
                </div>

                <a class="mc-whatsapp-link" href="https://wa.me/50254001440" target="_blank">
                    <i class="bi bi-whatsapp"></i>
                    WhatsApp
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
            <div id="toastSuccess" class="toast align-items-center text-bg-success border-0 shadow-lg rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body fw-semibold">
                        @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('toastSuccess');
                if (toastEl) {
                    var toast = new bootstrap.Toast(toastEl, {
                        delay: 2500
                    });
                    toast.show();
                }
            });
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>