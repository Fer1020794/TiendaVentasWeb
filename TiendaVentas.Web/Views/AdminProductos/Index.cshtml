@model List<TiendaVentas.Web.Models.Producto>

@{
    ViewData["Title"] = "Administrar Productos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-bold mb-1">Panel de Productos</h1>
            <p class="text-muted mb-0">Administra el catálogo de MC Nails.</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="AdminCategorias" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                Categorías
            </a>

            <a asp-controller="AdminProductos" asp-action="Create" class="btn btn-dark rounded-pill">
                Nuevo producto
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Imagen</th>
                                <th>Producto</th>
                                <th>Categoría</th>
                                <th>Precio</th>
                                <th>Disponibilidad</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <img src="@(string.IsNullOrWhiteSpace(item.Imagen_Url) ? "/images/no-image.png" : item.Imagen_Url)"
                                             alt="@item.Nombre"
                                             style="width:70px; height:70px; object-fit:cover; border-radius:12px;" />
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@item.Nombre</div>
                                        <small class="text-muted">ID: @item.Id_Producto</small>
                                    </td>
                                    <td>@item.Categoria</td>
                                    <td>Q @item.Precio.ToString("N2")</td>
                                    <td>
                                        @if (item.Stock > 0)
                                        {
                                            <span class="badge bg-success">Disponible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Agotado</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Estado == "A")
                                        {
                                            <span class="badge bg-primary">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <a asp-action="Edit"
                                                   asp-route-id="@item.Id_Producto"
                                                   class="btn btn-sm btn-outline-primary rounded-pill">
                                                Editar
                                            </a>

                                            @if (item.Estado == "A")
                                            {
                                                <form asp-action="Desactivar" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.Id_Producto" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                                        Desactivar
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning rounded-4 text-center">
            No hay productos registrados.
        </div>
    }
</div>