@model TiendaVentas.Web.Models.ProductoFormViewModel
@using TiendaVentas.Web.Models

@{
    ViewData["Title"] = "Nuevo Producto";
    var categorias = ViewBag.Categorias as List<Categoria> ?? new List<Categoria>();
}

<div class="container py-4 mb-5">
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-1">Nuevo Producto</h1>
            <p class="text-muted mb-0">Agrega un nuevo producto al catálogo.</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" form="formProductoCreate" class="btn btn-dark rounded-pill px-4">
                Guardar producto
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Cancelar
            </a>
        </div>
    </div>

    <div class="card border-0 shadow rounded-4 mb-5">
        <div class="card-body p-4">
            <form id="formProductoCreate" asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Codigo_Producto" class="form-label">Código del producto</label>
                        <input asp-for="Codigo_Producto" class="form-control rounded-4" placeholder="Ej: MC-001" />
                        <span asp-validation-for="Codigo_Producto" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label">Nombre del producto</label>
                        <input asp-for="Nombre" class="form-control rounded-4" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Id_Categoria" class="form-label">Categoría</label>
                        <select asp-for="Id_Categoria" class="form-select rounded-4">
                            <option value="">Seleccione una categoría</option>
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Id_Categoria">@cat.Nombre</option>
                            }
                        </select>
                        <span asp-validation-for="Id_Categoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Estado" class="form-label">Estado</label>
                        <select asp-for="Estado" class="form-select rounded-4">
                            <option value="A">Activo</option>
                            <option value="I">Inactivo</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" rows="3" class="form-control rounded-4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Precio" class="form-label">Precio</label>
                        <input asp-for="Precio" class="form-control rounded-4" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label">Disponibilidad</label>
                        <select asp-for="Stock" class="form-select rounded-4">
                            <option value="1">Disponible</option>
                            <option value="0">Agotado</option>
                        </select>
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ImagenFile" class="form-label">Imagen del producto</label>
                        <input asp-for="ImagenFile" type="file" class="form-control rounded-4" accept="image/*" />
                        <span asp-validation-for="ImagenFile" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-dark rounded-pill px-4">
                        Guardar producto
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}