@model TiendaVentas.Web.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-bold mb-1">Nueva Categoría</h1>
            <p class="text-muted mb-0">Agrega una nueva categoría al sistema.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-dark rounded-pill">
            Volver
        </a>
    </div>

    <div class="card border-0 shadow rounded-4">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control rounded-4" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Estado" class="form-label">Estado</label>
                        <select asp-for="Estado" class="form-select rounded-4">
                            <option value="A">Activa</option>
                            <option value="I">Inactiva</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" rows="4" class="form-control rounded-4"></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-dark rounded-pill px-4">
                        Guardar categoría
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}